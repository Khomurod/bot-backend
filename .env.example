BOT_TOKEN=your-telegram-bot-token
DATABASE_URL=postgresql://user:password@localhost:5432/driver_feedback
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
MANAGEMENT_GROUP_ID=-1002997837889
MEDIA_STORAGE_CHAT_ID=-1002997837889
EMPLOYEE_GROUP_ID=-1003284808897
# Optional seed for employee birthday wish schedule (admin UI overrides after first boot)
# EMPLOYEE_BIRTHDAY_TZ=Asia/Tashkent
# EMPLOYEE_BIRTHDAY_HOUR=0
# EMPLOYEE_BIRTHDAY_MINUTE=0
JWT_SECRET=change-this-to-a-random-string
PORT=3001
RENDER_EXTERNAL_URL=https://your-render-app.onrender.com
# Comma-separated admin panel origins allowed by CORS (optional on Render — defaults to RENDER_EXTERNAL_URL)
# CORS_ALLOWED_ORIGINS=https://your-render-app.onrender.com

# Facebook self-serve connect flow
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
WEBHOOK_VERIFY_TOKEN=choose-a-random-verify-token
META_LOGIN_CONFIG_ID=
META_REQUESTED_PERMISSIONS=pages_show_list,pages_read_engagement,pages_manage_metadata,leads_retrieval,pages_manage_ads,ads_management,pages_messaging,business_management
FACEBOOK_TOKEN_ENCRYPTION_KEY=change-this-to-a-separate-random-string
LEADS_INTERNAL_SHARED_SECRET=change-this-to-a-random-internal-secret
# Facebook lead auto-SMS copy is configured in Admin → Facebook Leads (not in env vars).
LEADS_BOT_PORT=8000
# Leads Python process calls the Node API (defaults to http://127.0.0.1:$PORT)
# LOCAL_API_BASE_URL=http://127.0.0.1:3001

# WenzeLeadBots — Facebook leads, /connect, lead Telegram posts (must differ from BOT_TOKEN)
TELEGRAM_BOT_TOKEN=your-wenze-leads-bot-token
# Wenze Facebook Leads group id — RC inbound forwards, auto-SMS monospace mirrors, reply-to-SMS (Node + leads-bot)
TELEGRAM_CHAT_ID=-1001234567890
# Legacy single-page token (optional; multi-page /connect uses DB-stored tokens)
META_PAGE_ACCESS_TOKEN=

# Bitrix24 — dual delivery for Facebook leads (Telegram + CRM)
# Create at wenze.bitrix24.com → Developer resources → Incoming webhook (scope: crm)
BITRIX24_ENABLED=false
BITRIX24_WEBHOOK_URL=https://wenze.bitrix24.com/rest/1/your-incoming-webhook-secret/
# lead (default) or deal
BITRIX24_ENTITY=lead
# Optional: Bitrix user id to assign new records
BITRIX24_ASSIGNED_BY_ID=
BITRIX24_SOURCE_ID=
BITRIX24_SOURCE_DESCRIPTION=Facebook / bot-backend
# Required when BITRIX24_ENTITY=deal (copy from CRM pipeline settings)
BITRIX24_DEAL_CATEGORY_ID=
BITRIX24_DEAL_STAGE_ID=
# Optional: override config/bitrix24LeadFieldMap.json (JSON string: defaults, custom, statusId)
# BITRIX24_FIELD_MAP={"statusId":"INCOMING"}
# BITRIX24_FIELD_MAP_BY_FORM_ID={"1489274899611047":{"custom":{}}}
# BITRIX24_STATUS_ID=INCOMING

# When false, load-ingest skips forwarding parse-failure hints to DISPATCH_ETA_TEST_GROUP_ID (never driver chats).
LOAD_INGEST_NOTIFY_EXTRACTION_FAILURE=false

# ─── Samsara Alert Bot ───
# Required whenever the Leads bot is enabled: must be a different bot than TELEGRAM_BOT_TOKEN (only one getUpdates poll per bot).
SAMSARA_BOT_TOKEN=your-samsara-telegram-bot-token
SAMSARA_API_KEY=your-samsara-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
SAMSARA_API_BASE=https://api.samsara.com
SAMSARA_PORT=3002
# Delay before re-fetching Samsara for missing dashcam video (ms). Default 90000 (90s).
# SAMSARA_VIDEO_RETRY_DELAY_MS=90000
# SAMSARA_VIDEO_RETRY_ENABLED=false
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# EVO ELD fallback for /location
EVO_ELD_API_KEY=your-evo-eld-api-key
EVO_ELD_PROVIDER_TOKEN=your-evo-eld-provider-token
EVO_ELD_USDOT_NUMBER=your-usdot-number
EVO_ELD_API_BASE=https://read.evoeld.com/api/v2

# TT ELD fallback for /location (used after EVO ELD)
TT_ELD_API_KEY=your-tt-eld-api-key
TT_ELD_PROVIDER_TOKEN=your-tt-eld-provider-token
TT_ELD_USDOT_NUMBER=your-usdot-number
TT_ELD_API_BASE=https://read.tteld.com/api/externalservice

# Optional: ETA test destination group ("Automatic updating (Test)" supergroup).
# Scheduled test-mode ETA posts here; /status in this chat prompts for a driver name.
DISPATCH_ETA_TEST_GROUP_ID=-1001234567890

# Datatruck peer bot — reactions/banter when @datatruck_driver_bot posts in driver groups
# Requires Bot-to-Bot Communication Mode ON in @BotFather for @wenzefeedback_bot
# DATATRUCK_PEER_ENABLED=true
# DATATRUCK_PEER_BOT_USERNAME=datatruck_driver_bot
# DATATRUCK_LOAD_FLAME_CHANCE=0.35
# DATATRUCK_BANTER_MAX_PER_HOUR_PER_CHAT=10

# Datatruck OpenAPI (read-only) — mileage bonus feature for company drivers.
# Create a token in the Datatruck dashboard (Developer resources). COMPANY is
# the subdomain of your Datatruck URL (e.g. "wenze" for wenze.datatruck.io).
DATATRUCK_API_TOKEN=your-datatruck-api-token
DATATRUCK_COMPANY=wenze

# Datatruck BOL/POD delivery — forward Bill of Lading / Proof of Delivery
# uploads to the matching driver's Telegram group. Uses the read-only OpenAPI
# above; matches each order to its group by unit number, then driver name.
# DATATRUCK_DOC_DELIVERY_ENABLED=true
# DATATRUCK_DOC_POLL_MINUTES=15
# DATATRUCK_DOC_LOOKBACK_DAYS=7
# Documents uploaded before this ISO timestamp are treated as backfill and
# never sent. Leave unset to use the feature's first-activation time.
# DATATRUCK_DOC_SINCE=2026-06-29T00:00:00Z
# DATATRUCK_DOC_MAX_FILE_MB=45
# Datatruck returns document file_link as a relative storage key; this base is
# prepended to build the public, fetchable URL.
# DATATRUCK_DOC_MEDIA_BASE_URL=https://tms-datatruck.s3-accelerate.amazonaws.com/static/

# Mileage bonus Telegram workflow. Use immutable Telegram numeric user IDs for
# authorization; usernames are retained only as a compatibility fallback when
# the ID list is empty.
MILEAGE_BONUS_GROUP_CHAT_ID=-5170359585
MILEAGE_BONUS_ACCOUNTING_USER_IDS=123456789,987654321
MILEAGE_BONUS_ACCOUNTING_USERNAMES=cameron_acc,Ellaaccounting

# Home-time requests: who may press Approve / Do Not Approve on a request card.
# Prefer immutable Telegram numeric user IDs; usernames are a fallback when the
# ID list is empty. Defaults to tomr_robins0n,SaffieBNett.
HOME_TIME_APPROVER_USER_IDS=
HOME_TIME_APPROVER_USERNAMES=tomr_robins0n,SaffieBNett

# Driver Raise Approval (75¢/mile) — email OTP channel.
# Primary setup is in the admin panel (Driver Raises → Settings): enter the Gmail
# address + App Password there; the password is stored encrypted (reuses
# FACEBOOK_TOKEN_ENCRYPTION_KEY). The env vars below are an OPTIONAL fallback used
# only when the panel has no credentials configured.
# Use a Gmail App Password (requires 2-Step Verification):
# https://myaccount.google.com/apppasswords  — NOT your normal Gmail password.
# (The other OTP channel, RingCentral SMS, reuses the RC_* vars above.)
# GMAIL_USER=you@yourcompany.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
# Optional: override the From address (defaults to GMAIL_USER)
# GMAIL_FROM=you@yourcompany.com

# Groq AI — dispatch parsing, admin AI reports/insights, Ask Data, chat annotation
GROQ_API_KEY=your-groq-api-key
# Optional model overrides (defaults: llama-3.3-70b-versatile / llama-3.1-8b-instant)
# GROQ_AI_MODEL=llama-3.3-70b-versatile
# GROQ_AI_FAST_MODEL=llama-3.1-8b-instant
# Comma-separated fallback chain when a model hits TPM/RPM (per-model limits on Groq)
# GROQ_AI_FALLBACK_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,openai/gpt-oss-20b
# Annotator-only override + cooldown when every Groq model returns 429
# ANNOTATOR_GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile
# ANNOTATOR_RATE_LIMIT_COOLDOWN_MS=15000

# Gemini — dispatch/load parsing and annotator fallback when Groq is exhausted
GEMINI_API_KEY=your-gemini-api-key
# Higher free-tier headroom first (gemini-3.1-flash-lite before gemini-2.5-flash)
# GEMINI_TEXT_MODELS=gemini-3.1-flash-lite,gemini-3-flash,gemini-2.5-flash-lite,gemini-2.5-flash
# GEMINI_PINNED_CONTEXT_MODELS=

# /location driver name: group title is authoritative; warn if Samsara vehicle label differs (default: warn and send pin)
# LOCATION_DRIVER_NAME_STRICT=false

# Optional Google Maps fallback for ETA geocoding/routing
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_GEOCODING_API_BASE=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_ROUTES_API_BASE=https://routes.googleapis.com/directions/v2:computeRoutes
