BOT_TOKEN=your-telegram-bot-token
DATABASE_URL=postgresql://user:password@localhost:5432/driver_feedback
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
MANAGEMENT_GROUP_ID=-1002997837889
MEDIA_STORAGE_CHAT_ID=-1002997837889
EMPLOYEE_GROUP_ID=-1003284808897
JWT_SECRET=change-this-to-a-random-string
PORT=3001
RENDER_EXTERNAL_URL=https://your-render-app.onrender.com

# Facebook self-serve connect flow
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
WEBHOOK_VERIFY_TOKEN=choose-a-random-verify-token
META_LOGIN_CONFIG_ID=
META_REQUESTED_PERMISSIONS=pages_show_list,pages_read_engagement,pages_manage_metadata,leads_retrieval,pages_manage_ads,ads_management,pages_messaging,business_management
FACEBOOK_TOKEN_ENCRYPTION_KEY=change-this-to-a-separate-random-string
LEADS_INTERNAL_SHARED_SECRET=change-this-to-a-random-internal-secret
LEADS_BOT_PORT=8000
# Leads Python process calls the Node API (defaults to http://127.0.0.1:$PORT)
# LOCAL_API_BASE_URL=http://127.0.0.1:3001

# WenzeLeadBots — Facebook leads, /connect, lead Telegram posts (must differ from BOT_TOKEN)
TELEGRAM_BOT_TOKEN=your-wenze-leads-bot-token
# Wenze Facebook Leads group id — RingCentral inbound SMS/MMS forwards land here
TELEGRAM_CHAT_ID=-1001234567890
# Legacy single-page token (optional; multi-page /connect uses DB-stored tokens)
META_PAGE_ACCESS_TOKEN=

# When false, load-ingest skips forwarding parse-failure hints to DISPATCH_ETA_TEST_GROUP_ID (never driver chats).
LOAD_INGEST_NOTIFY_EXTRACTION_FAILURE=false

# ─── Samsara Alert Bot ───
# Required whenever the Leads bot is enabled: must be a different bot than TELEGRAM_BOT_TOKEN (only one getUpdates poll per bot).
SAMSARA_BOT_TOKEN=your-samsara-telegram-bot-token
SAMSARA_API_KEY=your-samsara-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
SAMSARA_API_BASE=https://api.samsara.com
SAMSARA_PORT=3002
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# EVO ELD fallback for /location
EVO_ELD_API_KEY=your-evo-eld-api-key
EVO_ELD_PROVIDER_TOKEN=your-evo-eld-provider-token
EVO_ELD_USDOT_NUMBER=your-usdot-number
EVO_ELD_API_BASE=https://read.evoeld.com/api/v2

# TT ELD fallback for /location (used after EVO ELD)
TT_ELD_API_KEY=your-tt-eld-api-key
TT_ELD_PROVIDER_TOKEN=your-tt-eld-provider-token
TT_ELD_USDOT_NUMBER=your-usdot-number
TT_ELD_API_BASE=https://read.tteld.com/api/externalservice

# Optional: ETA test destination group (when test toggle is enabled)
DISPATCH_ETA_TEST_GROUP_ID=-1001234567890

# Optional Google Maps fallback for ETA geocoding/routing
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_GEOCODING_API_BASE=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_ROUTES_API_BASE=https://routes.googleapis.com/directions/v2:computeRoutes
