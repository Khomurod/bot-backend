{
  "name": "driver-feedback-bot",
  "version": "1.0.0",
  "description": "Telegram Driver Feedback System with bot, API, and admin panel",
  "main": "index.js",
  "scripts": {
    "postinstall": "npm install --prefix samsara-integration && node scripts/install-leads-bot-deps.js",
    "start": "node index.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js && python -m unittest discover -s leads-bot -p \"test_*.py\"",
    "bot": "node bot/bot.js",
    "server": "node server/api.js",
    "dev": "node index.js",
    "seed-admin": "node scripts/seed-admin.js",
    "init-db": "node scripts/init-db.js",
    "backfill-driver-profiles": "node scripts/backfill-driver-profiles.js",
    "migrate-media": "node scripts/migrate-media.js",
    "migrate-multi-media": "node scripts/migrate-multi-media.js",
    "discover-bitrix-fields": "node scripts/discover-bitrix-lead-fields.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.4.4",
    "multer": "^2.1.1",
    "openai": "^6.29.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "telegraf": "^4.15.3",
    "tesseract.js": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
