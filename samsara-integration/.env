# Local override file for running samsara-integration standalone.
# Prefer using the repository root .env when starting from the project root.

TELEGRAM_BOT_TOKEN=
SAMSARA_API_KEY=

# Main Bot for Driver Group Forwarding
BOT_TOKEN=
EMPLOYEE_GROUP_ID=

# Database
DATABASE_URL=

# Port for the Samsara bot's health-check Express server (must differ from main app)
PORT=3002
WEBHOOK_PORT=3002

# Upstash Redis (for persistent subscriber storage — leave blank to use local JSON fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to 'true' and provide PUBLIC_WEBHOOK_URL to use webhook mode instead of polling
USE_WEBHOOK=false
PUBLIC_WEBHOOK_URL=
HARDCODED_GROUP_ID=
