# ==========================================================================
# Samsara → Telegram poller — environment variables (standalone service)
# Copy this file to `.env` and fill in the real values.
#
# IMPORTANT: DATABASE_URL and BOT_TOKEN MUST be identical to the values used
# by the main "driver-feedback-bot" hub. That shared database + shared bot are
# how the two services keep talking to each other after the split.
# ==========================================================================

# --- Telegram bots ---
# The Samsara notification bot's OWN token (e.g. @wenzesambot).
TELEGRAM_BOT_TOKEN=

# The MAIN feedback bot token (e.g. @wenzefeedback_bot). Used send-only to post
# the video + friendly caption into the matched driver group. Same value as the
# main hub's BOT_TOKEN.
BOT_TOKEN=

# --- Samsara API ---
SAMSARA_API_KEY=
SAMSARA_API_BASE=https://api.samsara.com

# --- Shared PostgreSQL database (MUST match the main hub's DATABASE_URL) ---
DATABASE_URL=

# --- Group routing ---
MANAGEMENT_GROUP_ID=
EMPLOYEE_GROUP_ID=
# Optional: the fixed "Samsara Notifications" group id. Leave blank to use the
# built-in default baked into the code.
HARDCODED_GROUP_ID=

# --- AI for the friendly driver-group caption (the "joke" message) ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Optional: persistent subscriber storage (survives redeploys) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Local health-check server port (Render sets PORT automatically) ---
PORT=3002

# --- Optional Telegram webhook mode (default is long-polling) ---
USE_WEBHOOK=false
PUBLIC_WEBHOOK_URL=
